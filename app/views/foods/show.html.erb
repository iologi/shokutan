<div class="max-w-3xl mx-auto p-4">
  <div class="bg-white rounded-xl shadow p-6">
  <!-- 画像 + 基本情報 -->
  <div class="flex gap-4">
    <!-- 食材画像 -->
    <div class="w-1/2">
      <%= image_tag(@food.image_url || "sample.png", class: "w-full aspect-square object-cover") %>
    </div>
    <div class="w-1/2 flex flex-col justify-start gap-3">
      <!-- 食材名 -->
      <h1 class="text-3xl font-bold ">
        <%= @food.name %>
      </h1>
      <!-- カテゴリー -->
      <p class="text-gray-800 text-xl">
        カテゴリー：<%= @food.category.name %>
      </p>
      <!-- レア度 -->
      <p class="text-xl font-semibold text-gray-800 mt-1">
        レア度：
        <span class="font-bold tracking-wide text-yellow-400 drop-shadow">
          <%= "♦" * @food.rarity_before_type_cast %>
        </span>
      </p>
      <% if user_signed_in? %>
        <div class="flex items-center gap-4 mt-3">
          <!-- 食べたボタン -->
          <%= render 'eaten_foods/eaten_button', { food: @food } %>
          <!-- 「食べたい」(ブックマーク) -->
          <%= render 'wishlist_buttons', { food: @food } %>
        </div>
        <!-- 食べたボタン日付入力フォーム -->
        <div id="eaten-food-form-<%= @food.id %>"></div>
      <% end %>
    </div>
  </div>
  <!-- 特徴 -->
  <div class="mt-6">
    <h1 class="text-lg font-semibold mb-2">特徴</h1>
    <p class="text-gray-700 leading-relaxed">
      <%= @food.description %>
    </p>
  </div>
  <!-- レビュー情報 -->
  <div class="mt-6">
    <h1 class="text-lg font-semibold mb-2">レビュー一覧</h1>
    <% if @eaten_foods.present? %>
      <% @eaten_foods.each do |eaten_food| %>
        <% next if eaten_food.review.blank? %>
        <div class="mt-4 p-4 rounded-lg border border-gray-200 w-full h-auto">
          <!-- 食べた日 + 満足度 -->
          <div class="flex items-center gap-6 mb-3">
            <p class="text-gray-800 font-semibold whitespace-nowrap">食べた日：<%= eaten_food.ate_on %></p>
            <div class="flex items-center gap-1 whitespace-nowrap">
              <p class="text-gray-800 font-semibold">満足度：</p>
              <div class="raty inline-block" data-score="<%= eaten_food.review.satisfaction %>"></div>
            </div>
          </div>
          <!-- コメント -->
          <p class="text-gray-700 ">
            <%= eaten_food.review.comment %>
          </p>
        </div>
      <% end %>
    <% end %>
  </div>

<script>
document.addEventListener("turbo:load", () => {
  document.querySelectorAll(".raty").forEach((elem) => {
    const score = Number(elem.dataset.score);

    elem.innerHTML = "";

    window.raty(elem, {
      starOn: "<%= asset_path('star-on.png') %>",
      starOff: "<%= asset_path('star-off.png') %>",
      starHalf: "<%= asset_path('star-half.png') %>",
      score: score,
      readOnly: true,
    });
  });
});
</script>
