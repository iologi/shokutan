<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md bg-white shadow-md rounded-lg p-8">
    <h2 class="text-2xl font-bold mb-6 text-center text-gray-800"><%= t('.title') %></h2>

    <%= form_with model: resource, as: resource_name, url: session_path(resource_name), class: "space-y-5" do |f| %>
      <div class="field">
        <p><%= f.label :email, class: "block text-sm font-medium text-gray-700" %></p>
        <p><%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm" %></p>
      </div>

      <div class="field">
        <p><%= f.label :password, class: "block text-sm font-medium text-gray-700" %></p>
        <p><%= f.password_field :password, autocomplete: "current-password", class: "mt-1 w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm" %></p>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="field">
          <p><%= f.check_box :remember_me %></p>
          <p><%= f.label :remember_me %></p>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "ログイン", class: "w-full bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700 transition" %>
      </div>
    <% end %>

    <div class="mt-4">
      <%= link_to t('.password_forget'), '#', class: "text-blue-600 hover:underline" %>
    </div>
  </div>
</div>