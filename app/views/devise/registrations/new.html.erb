<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-md bg-white shadow-md rounded-lg p-8">
    <h2 class="text-2xl font-bold mb-6 text-center text-gray-800">ユーザー登録</h2>
    
    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), class: "space-y-5" do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <p><%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700" %></p>
        <p><%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm" %></p>
      </div>

      <div class="field">
        <p><%= f.label :password, class: "block text-sm font-medium text-gray-700" %></p>
        <p><%= f.password_field :password, autocomplete: "new-password", class: "mt-1 w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm" %></p>
      </div>

      <div class="field">
        <p><%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700" %></p>
        <p><%= f.password_field :password_confirmation, autocomplete: "new-password", class: "mt-1 w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm" %></p>
      </div>

      <div class="actions">
        <%= f.submit "登録", class: "w-full bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700 transition" %>
      </div>
    <% end %>

    <div class="mt-4">
      <%= link_to "ログインページへ", new_user_session_path, class: "text-blue-600 hover:underline" %>
    </div>
  </div>
</div>
